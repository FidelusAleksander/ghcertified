{
  "name": "quizdown",
  "version": "0.1.0",
  "description": "Parse markdown files with checkbox answers into structured quiz objects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
